{
  "manifest_version": 3,
  "name": "ChatGPT DOM Trimmer",
  "version": "0.2.0",
  "description": "Collapse older ChatGPT turns to keep long chats responsive.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Open ChatGPT DOM Trimmer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}